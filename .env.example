# Copy to .env and edit, then `source .env` (or `set -a; source .env; set +a`).

# Your GCP project. The datasets below are created inside it.
GCP_PROJECT=lng-geo-play

# BigQuery location. Use the SAME region as your existing geo-play datasets.
# Common choices: US (multi-region default) or asia-south1 (Mumbai).
BQ_LOCATION=US

# Prefix applied to every dataset this project creates (raw / staging / intermediate
# / marts). Keeps prototype datasets clearly named and easy to drop later.
# Result: gaming_proto_raw, gaming_proto_staging, gaming_proto_marts, ...
DBT_DATASET_PREFIX=gaming_proto_

# AUTH — pick one:
#   (recommended) run once:  gcloud auth application-default login
#   (service-account key)     GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
